# Installed automatically as ~/.config/inbrief/config on first use.

[gmail]
client_secrets_file = credentials.json
token_file = token.json
max_messages = 20
max_body_chars = 8000

[ai]
# anthropic, openai, or deepseek
provider = anthropic
# Any model ID supported by the selected provider. Examples:
# claude-opus-4-8, claude-sonnet-4-6, gpt-5.5, deepseek-v4-flash
model = claude-sonnet-4-6
max_tokens = 8192
timeout_seconds = 120

[anthropic]
# Prefer the INBRIEF_ANTHROPIC_API_KEY environment variable.
api_key =

[openai]
# Prefer the INBRIEF_OPENAI_API_KEY environment variable.
api_key =
# Optional: none, minimal, low, medium, high, or xhigh
reasoning_effort =

[deepseek]
# Prefer the INBRIEF_DEEPSEEK_API_KEY environment variable.
api_key =
base_url = https://api.deepseek.com
# Optional: enabled or disabled. Omit to use the model default.
thinking =

[email]
recipient = you@example.com
sender_name = InBrief
sender = you@example.com
subject_prefix = Digest

[digest]
timezone = Europe/London
persona = a technology leader
priorities = AI, cybersecurity, cloud infrastructure, and engineering leadership

[labels]
Technology = Label_123456789

[mail]
smtp_host = smtp.example.com
smtp_port = 587
security = starttls
timeout_seconds = 30
# Prefer INBRIEF_SMTP_USER and INBRIEF_SMTP_PASSWORD.
smtp_user =
smtp_password =
